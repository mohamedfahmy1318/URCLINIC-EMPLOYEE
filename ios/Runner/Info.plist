<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>URCLINIC Employee</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>URCLINIC Employee</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
	<key>NSCalendarsUsageDescription</key>
	<string>URCLINIC Employee needs calendar access so you can add appointment events to your calendar when you choose to do so.</string>
	<key>NSCameraUsageDescription</key>
	<string>URCLINIC needs camera access so you can take and upload profile pictures and medical document photos directly within the app.</string>
	<key>NSFaceIDUsageDescription</key>
	<string>URCLINIC Employee uses Face ID to securely access encrypted credentials stored on your device when available.</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>URCLINIC Employee uses location to help fill clinic and address details on maps during your workflows. The app only uses location for these features.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>URCLINIC Employee uses your location only while you are using the app to help fill clinic and address details on maps. Your location is not used in the background.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>URCLINIC needs permission to save edited images and generated files to your photo library when requested by you.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>URCLINIC needs photo library access so you can select and upload existing profile pictures and medical document images from your device.</string>
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	<key>UIBackgroundModes</key>
	<array>
		<string>fetch</string>
		<string>remote-notification</string>
	</array>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
</dict>
</plist>
